{
  "name": "the-vibecoding-handbook",
  "displayName": "The Vibe Coding Handbook",
  "description": "AI-first project governance — context, policies, and prompt optimization for vibe coding",
  "version": "1.0.2",
  "publisher": "TheVibecoder",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dangelBorges/the-vibecoding-handbook"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Machine Learning",
    "Snippets",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "vibe coding",
    "ai",
    "cursor",
    "agents",
    "prompt",
    "context",
    "governance"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "the-vibecoding-handbook-sidebar",
          "title": "Vibe Coding",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "the-vibecoding-handbook-sidebar": [
        {
          "id": "the-vibecoding-handbook.policies",
          "name": "Policies",
          "when": "the-vibecoding-handbook.hasSetup"
        },
        {
          "id": "the-vibecoding-handbook.decisions",
          "name": "Decisions",
          "when": "the-vibecoding-handbook.hasSetup"
        },
        {
          "id": "the-vibecoding-handbook.stack",
          "name": "Stack",
          "when": "the-vibecoding-handbook.hasSetup"
        }
      ]
    },
    "commands": [
      {
        "command": "the-vibecoding-handbook.init",
        "title": "Vibe: Initialize Project",
        "category": "Vibe Coding",
        "icon": "$(rocket)"
      },
      {
        "command": "the-vibecoding-handbook.check",
        "title": "Vibe: Check Project",
        "category": "Vibe Coding",
        "icon": "$(check)"
      },
      {
        "command": "the-vibecoding-handbook.context",
        "title": "Vibe: Refresh Context",
        "category": "Vibe Coding",
        "icon": "$(refresh)"
      },
      {
        "command": "the-vibecoding-handbook.optimize",
        "title": "Vibe: Optimize Prompt",
        "category": "Vibe Coding",
        "icon": "$(wand)"
      },
      {
        "command": "the-vibecoding-handbook.reviewActive",
        "title": "Vibe: Review Active File",
        "category": "Vibe Coding",
        "icon": "$(eye)"
      },
      {
        "command": "the-vibecoding-handbook.reviewChanged",
        "title": "Vibe: Review Changed Files",
        "category": "Vibe Coding",
        "icon": "$(eye)"
      },
      {
        "command": "the-vibecoding-handbook.reviewStaged",
        "title": "Vibe: Review Staged Files",
        "category": "Vibe Coding",
        "icon": "$(eye)"
      },
      {
        "command": "the-vibecoding-handbook.reviewBase",
        "title": "Vibe: Review Against Base",
        "category": "Vibe Coding",
        "icon": "$(git-compare)"
      },
      {
        "command": "the-vibecoding-handbook.reviewFix",
        "title": "Vibe: Review & Fix Changed Files",
        "category": "Vibe Coding",
        "icon": "$(wrench)"
      },
      {
        "command": "the-vibecoding-handbook.chat",
        "title": "Vibe: Chat / Plan Task",
        "category": "Vibe Coding",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "the-vibecoding-handbook.sync",
        "title": "Vibe: Sync Templates & Prompts",
        "category": "Vibe Coding",
        "icon": "$(library)"
      },
      {
        "command": "the-vibecoding-handbook.showContext",
        "title": "Vibe: Show Project Context",
        "category": "Vibe Coding",
        "icon": "$(book)"
      },
      {
        "command": "the-vibecoding-handbook.openAgents",
        "title": "Open AGENTS.md",
        "category": "Vibe Coding",
        "icon": "$(file-code)"
      },
      {
        "command": "the-vibecoding-handbook.openIdeRules",
        "title": "Open .iderules",
        "category": "Vibe Coding",
        "icon": "$(file-code)"
      },
      {
        "command": "the-vibecoding-handbook.refreshContext",
        "title": "Refresh Context",
        "category": "Vibe Coding",
        "icon": "$(refresh)"
      },
      {
        "command": "the-vibecoding-handbook.changeLanguage",
        "title": "Change Language",
        "category": "Vibe Coding",
        "icon": "$(globe)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "the-vibecoding-handbook.init"
        },
        {
          "command": "the-vibecoding-handbook.check"
        },
        {
          "command": "the-vibecoding-handbook.context"
        },
        {
          "command": "the-vibecoding-handbook.optimize"
        },
        {
          "command": "the-vibecoding-handbook.reviewActive"
        },
        {
          "command": "the-vibecoding-handbook.reviewChanged"
        },
        {
          "command": "the-vibecoding-handbook.reviewStaged"
        },
        {
          "command": "the-vibecoding-handbook.reviewBase"
        },
        {
          "command": "the-vibecoding-handbook.reviewFix"
        },
        {
          "command": "the-vibecoding-handbook.chat"
        },
        {
          "command": "the-vibecoding-handbook.sync"
        },
        {
          "command": "the-vibecoding-handbook.showContext"
        },
        {
          "command": "the-vibecoding-handbook.openAgents"
        },
        {
          "command": "the-vibecoding-handbook.openIdeRules"
        },
        {
          "command": "the-vibecoding-handbook.changeLanguage"
        }
      ],
      "view/title": [
        {
          "command": "the-vibecoding-handbook.refreshContext",
          "when": "view == the-vibecoding-handbook.policies",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Vibe Coding",
      "properties": {
        "the-vibecoding-handbook.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show status notifications"
        },
        "the-vibecoding-handbook.autoCheckOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run vibe check on file save"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:unit": "tsc -p ./ && node --test dist/test/utils",
    "test": "tsc -p ./ && vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.7.0"
  }
}

